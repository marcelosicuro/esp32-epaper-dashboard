# Copie este arquivo para secrets.yaml e preencha seus dados
# O secrets.yaml NUNCA deve ser commitado no Git (já está no .gitignore)

wifi_ssid: "Nome da sua rede Wi-Fi"
wifi_password: "Senha do Wi-Fi"

ap_password: "painel1234"   # senha do hotspot de fallback

# Gere uma chave aleatória com:
#   python3 -c "import base64,os; print(base64.b64encode(os.urandom(32)).decode())"
api_key: "COLE_AQUI_SUA_CHAVE_BASE64_32_BYTES="

# Senha para atualização OTA (pode ser qualquer string)
ota_password: "minha-senha-ota"
